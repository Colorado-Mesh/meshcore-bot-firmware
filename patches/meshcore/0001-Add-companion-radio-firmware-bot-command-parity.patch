+  if (bot_prefs.enabled) {
+    scheduleBotLocalAdvert(bot_prefs.local_advert_interval_ms ? BOT_PREFS_INITIAL_LOCAL_ADVERT_MILLIS : 0);
+    scheduleBotFloodAdvert(bot_prefs.flood_advert_interval_ms);
+  } else {
+    scheduleBotLocalAdvert(0);

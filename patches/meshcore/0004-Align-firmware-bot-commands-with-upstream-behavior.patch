+BotWriteResult writeAckResponse(const BotMessage& message, const BotCommand& command, char* output, size_t output_len,
+                                size_t* written) {
+  if (written) *written = 0;
+  if (!output || output_len == 0) return BOT_WRITE_NO_SPACE;
+
+  const char* sender = message.sender_name[0] ? message.sender_name : "unknown";
+  const char* connection = message.channel_kind == BOT_CHANNEL_DM ? "direct" : "channel";
+  int n = command.args_len > 0 ? snprintf(output, output_len, "ack @[%s] %s | %s", sender, command.args, connection)
+                               : snprintf(output, output_len, "ack @[%s] | %s", sender, connection);
+  if (n < 0) {
+    output[0] = 0;
+    return BOT_WRITE_NO_SPACE;
+  }
+  size_t pos = (size_t)n;
+  bool truncated = pos >= output_len;
+  if (truncated) pos = output_len - 1;
+
+  if (message.path_hash_count > 0 && message.path_hash_size > 0) {
+    char path_info[36];
+    int value = message.packet_snr_quarters;
+    const char* sign = value < 0 ? "-" : "";
+    if (value < 0) value = -value;
+    int path_n = snprintf(path_info, sizeof(path_info), " path %uh x %uB snr %s%d.%02d",
+                          (unsigned)message.path_hash_count, (unsigned)message.path_hash_size, sign, value / 4,
+                          (value % 4) * 25);
+    if (path_n > 0) {
+      size_t path_len = (size_t)path_n;
+      size_t available = pos + 1 < output_len ? output_len - 1 - pos : 0;
+      size_t copy_len = path_len < available ? path_len : available;
+      if (copy_len > 0) memcpy(&output[pos], path_info, copy_len);
+      pos += path_len;
+      if (path_len > available) truncated = true;
+      output[pos < output_len ? pos : output_len - 1] = 0;
+    }
+  }
+
+  char received_at[9];
+  formatTimestampHms(message.received_at_timestamp, received_at, sizeof(received_at));
+  char received[32];
+  int received_n = snprintf(received, sizeof(received), " | Received at: %s", received_at);
+  if (received_n < 0) return BOT_WRITE_NO_SPACE;
+  size_t received_len = (size_t)received_n;
+  size_t available = pos + 1 < output_len ? output_len - 1 - pos : 0;
+  size_t copy_len = received_len < available ? received_len : available;
+  if (copy_len > 0) memcpy(&output[pos], received, copy_len);
+  pos += received_len;
+  if (received_len > available) truncated = true;
+  output[pos < output_len ? pos : output_len - 1] = 0;
+
+  size_t actual = boundedStrLen(output, output_len);
+  if (written) *written = actual;
+  return truncated ? BOT_WRITE_TRUNCATED : BOT_WRITE_OK;
+}

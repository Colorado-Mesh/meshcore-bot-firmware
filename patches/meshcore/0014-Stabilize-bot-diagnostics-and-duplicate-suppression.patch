+  uint32_t bias = hop * tier_step + hop * hop * BOT_HOP_GROW_MILLIS;
   if (bias > BOT_HOP_BIAS_MAX_MILLIS) bias = BOT_HOP_BIAS_MAX_MILLIS;
   return bias;
 }

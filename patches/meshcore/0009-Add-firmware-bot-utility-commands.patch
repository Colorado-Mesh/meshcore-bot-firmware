+void formatQuarters(int8_t quarters, char* output, size_t output_len) {
+  if (!output || output_len == 0) return;
+  int value = quarters;
+  const char* sign = value < 0 ? "-" : "";
+  if (value < 0) value = -value;
+  snprintf(output, output_len, "%s%d.%02d", sign, value / 4, (value % 4) * 25);
+}
